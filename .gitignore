# --- Binaries and Executables ---
# Compiled hardware-specific binaries
*.exe
*.exe~
*.dll
*.so
*.dylib

# Main project binary (standard naming)
bin/
out/
dist/
# If you name your binary specifically, add it here:
# my-app-name

# --- Dependencies ---
# Generally, you should commit go.mod and go.sum.
# The vendor directory is usually ignored unless you have a specific requirement to bundle it.
vendor/

# --- Test and Coverage ---
*.test
*.out
coverage.txt
profile.out

# --- Development Tools & IDEs ---
# JetBrains (GoLand, IntelliJ)
.idea/
*.iml

# VS Code
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# Vim/Emacs
*~
*.swp
*.swo

# --- Environment and Secrets ---
.env
.env.local
.env.*.local
*.pem
*.key

# --- OS Specific ---
.DS_Store
Thumbs.db

# log
*.log